{
  "name": "@datasynx/agentic-ai-shadowing",
  "version": "0.1.0",
  "description": "Agentic AI Shadowing — beobachtet Tasks, generiert SOPs, vollständig lokal und anonymisiert",
  "type": "module",
  "bin": {
    "shadowing": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "shadowing",
    "sop",
    "standard-operating-procedure",
    "task-tracking",
    "knowledge-management",
    "claude",
    "ai-agent"
  ],
  "author": {
    "name": "Datasynx AI",
    "url": "https://github.com/datasynx-ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/datasynx-ai/agentic-ai-shadowing.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "@datasynx/agentic-ai-cartography": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "@datasynx/agentic-ai-cartography": {
      "optional": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@inquirer/prompts": "^7.0.0",
    "better-sqlite3": "^12.6.0",
    "commander": "^12.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
