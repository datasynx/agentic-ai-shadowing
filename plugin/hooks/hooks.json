{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "npx shadowing hook",
            "timeout": 10,
            "statusMessage": "Logging action to shadowing"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx shadowing hook --event stop",
            "timeout": 10,
            "statusMessage": "Closing shadowing session"
          }
        ]
      }
    ]
  }
}
